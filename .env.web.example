# Firebase — même projet que crux_new_final (crux-8aa85)
# Copier ce fichier en .env et remplir les valeurs
REACT_APP_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
REACT_APP_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
REACT_APP_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
# Depuis Firebase Console → Paramètres du projet → Ajouter une app web
REACT_APP_FIREBASE_APP_ID=YOUR_WEB_APP_ID

# ZegoCloud — video conferencing web
REACT_APP_ZEGO_APP_ID=YOUR_ZEGO_APP_ID
REACT_APP_ZEGO_SERVER_SECRET=YOUR_ZEGO_SERVER_SECRET

GENERATE_SOURCEMAP=false
SKIP_PREFLIGHT_CHECK=true
DISABLE_ESLINT_PLUGIN=true
