<?xml version="1.0" encoding="utf-8"?>
<!--
   Sample backup rules file. The default rules will back up all of the app's files except
   database files. See the sections below for more details of what backs up where.
-->

<backup-scheme xmlns:android="http://schemas.android.com/apk/res/android">
    <domain name="sharedpref" />
    <domain name="database" />
    <domain name="file" />
    <domain name="cache" />
    <domain name="preferences" />
</backup-scheme>