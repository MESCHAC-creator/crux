# 🔐 CRUX - ENVIRONMENT VARIABLES
# ⚠️ NEVER COMMIT THIS FILE - Add to .gitignore!
# Copy this to .env.local and fill in your keys

# ═══════════════════════════════════════════════════════════════════════════
# FIREBASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
FIREBASE_PROJECT_ID=crux-8aa85
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=crux-8aa85.firebaseapp.com
FIREBASE_DATABASE_URL=https://crux-8aa85.firebaseio.com
FIREBASE_STORAGE_BUCKET=crux-8aa85.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID

# ═══════════════════════════════════════════════════════════════════════════
# AGORA (For screen sharing & small/medium conferences ≤300)
# Get from: https://console.agora.io/
# ═══════════════════════════════════════════════════════════════════════════
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_SIGNING_KEY=YOUR_AGORA_SIGNING_KEY
AGORA_CERTIFICATE=YOUR_AGORA_CERTIFICATE

# ═══════════════════════════════════════════════════════════════════════════
# JITSI (For large conferences 300-1000+)
# Use free tier or self-host: https://jitsi.org/
# ═══════════════════════════════════════════════════════════════════════════
JITSI_SFU_URL=https://meet.jitsi.org
JITSI_APP_ID=crux
JITSI_API_KEY=YOUR_JITSI_API_KEY_IF_SELF_HOSTED

# ═══════════════════════════════════════════════════════════════════════════
# AWS (For cloud recording & storage)
# Get from: https://console.aws.amazon.com/
# ⚠️ NEVER expose these in code - store only in .env.local!
# ═══════════════════════════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_BUCKET=crux-recordings-prod
AWS_S3_REGION=eu-west-1
AWS_S3_ENDPOINT=https://s3.eu-west-1.amazonaws.com

# ═══════════════════════════════════════════════════════════════════════════
# GOOGLE CLOUD (For transcription & speech-to-text)
# Get from: https://console.cloud.google.com/
# ═══════════════════════════════════════════════════════════════════════════
GOOGLE_CLOUD_PROJECT_ID=crux-8aa85
GOOGLE_CLOUD_SPEECH_KEY=YOUR_GOOGLE_CLOUD_SPEECH_API_KEY
GOOGLE_CLOUD_CREDENTIALS_JSON=path/to/credentials.json

# ═══════════════════════════════════════════════════════════════════════════
# LIVEKIT (Alternative SFU - optional)
# Get from: https://livekit.io/ or self-host
# ═══════════════════════════════════════════════════════════════════════════
LIVEKIT_URL=wss://livekit.your-domain.com
LIVEKIT_API_KEY=YOUR_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=YOUR_LIVEKIT_API_SECRET

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
ENVIRONMENT=production
DEBUG_MODE=false
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════
ENABLE_SCREEN_SHARING=true
ENABLE_RECORDING=true
ENABLE_CHAT=true
ENABLE_TRANSCRIPTION=true
ENABLE_VIRTUAL_BACKGROUNDS=true
ENABLE_BREAKOUT_ROOMS=true

# ═══════════════════════════════════════════════════════════════════════════
# LIMITS & QUOTAS
# ═══════════════════════════════════════════════════════════════════════════
MAX_PARTICIPANTS_SMALL_MEETING=50
MAX_PARTICIPANTS_MEDIUM_MEETING=300
MAX_PARTICIPANTS_LARGE_MEETING=1000
MAX_RECORDING_DURATION_HOURS=24
MAX_STORAGE_GB=1000

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: ANALYTICS & MONITORING
# ═══════════════════════════════════════════════════════════════════════════
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ANALYTICS_KEY=YOUR_ANALYTICS_KEY
MONITORING_URL=https://monitoring.your-domain.com

# ═══════════════════════════════════════════════════════════════════════════
# SUPPORT & FEEDBACK
# ═══════════════════════════════════════════════════════════════════════════
SUPPORT_EMAIL=support@crux.app
FEEDBACK_URL=https://feedback.crux.app
PRIVACY_POLICY_URL=https://crux.app/privacy
TERMS_URL=https://crux.app/terms
